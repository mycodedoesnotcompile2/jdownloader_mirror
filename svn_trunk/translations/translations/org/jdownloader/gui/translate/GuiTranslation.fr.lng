YoutubeHelper_getDescription_upperlowercase=Majuscules/minuscules : ajoutez [UC] ou [LC]. Exemple : *videoname[UC]*
YoutubeHelper_getDescription_replacetags=Remplacer les espaces par des underscores : ajoutez [SU]. Exemples : *videoname[UC][SU]* ou *channelname[SU]*
